  ];

  function renderTeam() {
    const container = document.getElementById('teamGrid');
    if (!container) return;
    let html = '';
    teamMembers.forEach(m => {
      html += `
        <div class="team-card">
          <div class="team-icon"><i class="fas ${m.icon}"></i></div>
          <div class="team-role">${m.role}</div>
          <div class="team-name">${m.name}</div>
          <div class="team-message">${m.msg}</div>
        </div>
      `;
    });
    container.innerHTML = html;
  }
  renderTeam();

  // Read More functionality (mobile only) – same as before
  function initReadMore() {
    const storyDiv = document.getElementById('storyText');
    if (!storyDiv) return;
    const fullHTML = storyDiv.innerHTML;
    const tempDiv = document.createElement('div');
    tempDiv.innerHTML = fullHTML;
    const textContent = tempDiv.textContent || tempDiv.innerText;
    const wordCount = textContent.split(/\s+/).length;
    const isMobile = window.innerWidth <= 768;
    const existingBtn = storyDiv.querySelector('.read-more-btn');
    if (existingBtn) existingBtn.remove();
    
    if (isMobile && wordCount > 100) {
      let words = textContent.split(/\s+/);
      let truncated = words.slice(0, 100).join(' ') + '...';
      const shortHTML = `<p>${truncated}</p>`;
      storyDiv.innerHTML = shortHTML;
      
      const button = document.createElement('button');
      button.className = 'read-more-btn';
      button.textContent = 'Read more';
      let expanded = false;
      button.onclick = () => {
        if (!expanded) {
          storyDiv.innerHTML = fullHTML;
          button.textContent = 'Show less';
          expanded = true;
        } else {
          storyDiv.innerHTML = shortHTML;
          button.textContent = 'Read more';
          expanded = false;
        }
      };
      storyDiv.appendChild(button);
    } else {
      storyDiv.innerHTML = fullHTML;
    }
  }
  
  initReadMore();
  window.addEventListener('resize', initReadMore);
  
  // AOS
  AOS.init({ duration: 800, once: true, offset: 120 });
  
  // Hamburger menu
  const menuToggle = document.getElementById('menuToggle');
  const navLinks = document.getElementById('navLinks');
  const body = document.body;
  
  function closeMenu() {
    navLinks.classList.remove('show');
    body.classList.remove('menu-open');
    const icon = menuToggle.querySelector('i');
    if (icon) icon.classList.remove('fa-times');
    if (icon) icon.classList.add('fa-bars');
  }
  function openMenu() {
    navLinks.classList.add('show');
    body.classList.add('menu-open');
    const icon = menuToggle.querySelector('i');
    if (icon) icon.classList.remove('fa-bars');
    if (icon) icon.classList.add('fa-times');
  }
  menuToggle.addEventListener('click', (e) => {
    e.stopPropagation();
    if (navLinks.classList.contains('show')) closeMenu();
    else openMenu();
  });
  document.querySelectorAll('.nav-links a').forEach(link => link.addEventListener('click', closeMenu));
  document.addEventListener('click', (e) => {
    if (navLinks.classList.contains('show') && !navLinks.contains(e.target) && e.target !== menuToggle && !menuToggle.contains(e.target)) {
      closeMenu();
    }
  });
</script>
</body>
